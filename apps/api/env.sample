# MongoDB — optional in development if you use localhost (see mongo-env default mongodb://localhost:27017/writual).
# Set either variable to override (e.g. MongoDB Atlas or Docker on another host):
# MONGODB_CONNECTION_URI=mongodb+srv://...
# MONGODB_URI=mongodb://127.0.0.1:27017/writual
#
# PDF AI import (optional). AI_SERVICE_SECRET must match INTERNAL_SERVICE_SECRET on @writual/writual-ai.
# Local dev: run `npm run dev:ai` (writual-ai default :8790). If Node fetch cannot reach localhost, use 127.0.0.1:
# AI_SERVICE_URL=http://127.0.0.1:8790
# On writual-ai only: omit HOST env for dual-stack bind; use HOST=0.0.0.0 only if IPv4-only is required (e.g. some containers).
# Prefer Railway private networking for AI_SERVICE_URL when both services run on Railway.
AI_SERVICE_URL=
AI_SERVICE_SECRET=
