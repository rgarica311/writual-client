{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "lib": ["ESNext", "ESNext.AsyncIterable"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
