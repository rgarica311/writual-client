{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "@writual/web#build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_GRAPHQL_ENDPOINT",
        "NEXT_PUBLIC_API_ORIGIN",
        "NEXT_PUBLIC_HOCUSPOCUS_URL",
        "NEXT_PUBLIC_FIREBASE_API_KEY",
        "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "NEXT_PUBLIC_FIREBASE_DATABASE_URL",
        "NEXT_PUBLIC_FIREBASE_PROJECT_ID",
        "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET",
        "NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
        "NEXT_PUBLIC_FIREBASE_APP_ID",
        "FIREBASE_PROJECT_ID",
        "FIREBASE_CLIENT_EMAIL",
        "FIREBASE_PRIVATE_KEY"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@writual/api#build": {
      "dependsOn": ["^build"],
      "env": [
        "MONGODB_CONNECTION_URI",
        "PORT",
        "AI_SERVICE_URL",
        "AI_SERVICE_SECRET"
      ],
      "outputs": ["dist/**"]
    },
    "@writual/writual-ai#build": {
      "dependsOn": ["^build"],
      "env": ["PORT", "GROQ_API_KEY", "GROQ_MODEL", "INTERNAL_SERVICE_SECRET"],
      "outputs": ["dist/**"]
    },
    "@writual/hocuspocus#build": {
      "dependsOn": ["^build"],
      "env": [
        "MONGODB_CONNECTION_URI",
        "MONGODB_DB_NAME",
        "FIREBASE_PROJECT_ID",
        "FIREBASE_CLIENT_EMAIL",
        "FIREBASE_PRIVATE_KEY",
        "FRONTEND_ORIGIN",
        "ALLOW_INSECURE_NO_AUTH",
        "APP_USERS_COLLECTION",
        "PROJECTS_COLLECTION",
        "SERVICE_NAME"
      ],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
